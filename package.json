{
  "name": "demo-comark-tiptap",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "vp check",
    "fmt": "vp check --fix",
    "test": "vp test",
    "test:lib": "vp test --project @comark/tiptap --project @comark/tiptap-vue",
    "test:e2e": "vp test --project e2e",
    "dev": "pnpm --filter @comark/playground-nuxt dev",
    "dev:nuxt": "pnpm --filter @comark/playground-nuxt dev",
    "dev:vue": "pnpm --filter @comark/playground-vue dev",
    "build": "pnpm --filter @comark/playground-nuxt build",
    "build:vue": "pnpm --filter @comark/playground-vue build",
    "typecheck": "pnpm --filter @comark/playground-nuxt typecheck && pnpm --filter @comark/playground-vue typecheck",
    "typecheck:nuxt": "pnpm --filter @comark/playground-nuxt typecheck",
    "typecheck:vue": "pnpm --filter @comark/playground-vue typecheck",
    "postinstall": "pnpm --filter @comark/playground-nuxt postinstall && vp config"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "happy-dom": "^20.9.0",
    "typescript": "npm:typescript@^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.16",
    "vite-plus": "npm:vite-plus@0.1.16",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.16",
    "vue-tsc": "npm:vue-tsc@^3.2.7"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "overrides": {
      "nitro": "https://pkg.pr.new/nitro@fbd3edc",
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.16",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.16"
    },
    "patchedDependencies": {
      "@nuxt/icon@2.2.1": ".patches/@nuxt__icon@2.2.1.patch"
    },
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ]
  }
}
